---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import type { BlogGitMeta } from '../utils/blogGitMeta';

interface Props extends CollectionEntry<'blog'>['data'] {
	gitMeta?: BlogGitMeta;
	headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, pubDate, gitMeta, headings = [] } = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body class="min-h-screen bg-background text-foreground">
		<Header />
		<main>
			<div class="article-shell">
				<div class="article-layout">
					{tocHeadings.length > 0 && (
						<aside class="toc-panel hidden md:block">
							<p class="eyebrow">Contents</p>
							<ul>
								{tocHeadings.map((heading) => (
									<li class:list={[heading.depth === 3 && 'toc-level-3']}>
										<a href={`#${heading.slug}`} data-toc-slug={heading.slug}>{heading.text}</a>
									</li>
								))}
							</ul>
						</aside>
					)}

					<article class="surface-panel overflow-hidden">
						<div class="article-header">
							<div class="article-header-grid">
								<div>
									<p class="eyebrow">Blog</p>
									<h1 class="display-title max-w-4xl text-[clamp(2.6rem,6vw,4.75rem)]">{title}</h1>
									<p class="lede mt-5 max-w-2xl">{description}</p>
								</div>

								<div class="article-note">
									<h3>Article info</h3>
									<div class="article-meta mt-4">
										<span class="meta-pill">
											Published <FormattedDate date={pubDate} />
										</span>
										{gitMeta?.writer && (
											<a class="meta-pill no-underline" href={gitMeta.writer.url} target="_blank" rel="noopener noreferrer">
												Writer @{gitMeta.writer.username}
											</a>
										)}
										{gitMeta?.modifiedBy && gitMeta.modifiedAt && (
											<a class="meta-pill no-underline" href={gitMeta.modifiedBy.url} target="_blank" rel="noopener noreferrer">
												Modified by @{gitMeta.modifiedBy.username} on <FormattedDate date={gitMeta.modifiedAt} />
											</a>
										)}
									</div>
								</div>
							</div>
						</div>

						<div class="prose max-w-none px-6 pb-10 sm:px-8 lg:px-12">
							<slot />
						</div>
					</article>
				</div>
			</div>
		</main>
		<Footer />
		<script>
			function initCodeCopyButtons() {
				const buttons = document.querySelectorAll('.code-copy-button');

				buttons.forEach((button) => {
					if (button.dataset.bound === 'true') {
						return;
					}

					button.dataset.bound = 'true';
					button.addEventListener('click', async () => {
						const container = button.closest('.code-example');
						const code = container?.getAttribute('data-code') ?? container?.querySelector('pre code')?.textContent ?? '';

						if (!code) {
							return;
						}

						try {
							await navigator.clipboard.writeText(code);
							button.classList.add('is-copied');
							window.setTimeout(() => {
								button.classList.remove('is-copied');
							}, 1600);
						} catch {
							button.classList.add('is-failed');
							window.setTimeout(() => {
								button.classList.remove('is-failed');
							}, 1600);
						}
					});
				});
			}

			function initScrollTracking() {
				const tocLinks = document.querySelectorAll('.toc-panel a[data-toc-slug]');
				if (tocLinks.length === 0) return;

				const tocItems = {};
				tocLinks.forEach(link => {
					const slug = link.dataset.tocSlug;
					const element = document.getElementById(slug);
					if (element) {
						tocItems[slug] = {
							element,
							tocLink: link
						};
					}
				});

				const observerOptions = {
					rootMargin: '-10% 0px -70% 0px',
					threshold: 0
				};

				const observerCallback = (entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting && tocItems[entry.target.id]) {
							// Remove active class from all TOC links
							Object.values(tocItems).forEach(item => {
								item.tocLink.classList.remove('active-toc-item');
							});
							
							// Add active class to current TOC link
							tocItems[entry.target.id].tocLink.classList.add('active-toc-item');
						}
					});
				};

				const observer = new IntersectionObserver(observerCallback, observerOptions);

				// Observe each section
				Object.values(tocItems).forEach(item => {
					if (item.element) {
						observer.observe(item.element);
					}
				});

				// Cleanup function
				return () => {
					observer.disconnect();
				};
			}

			document.addEventListener('astro:page-load', initCodeCopyButtons);
			initCodeCopyButtons();

			// Initialize scroll tracking
			let cleanupScrollTracking = null;
			document.addEventListener('astro:page-load', () => {
				if (cleanupScrollTracking) {
					cleanupScrollTracking();
				}
				cleanupScrollTracking = initScrollTracking();
			});
			
			// Initial call
			if (typeof initScrollTracking === 'function') {
				cleanupScrollTracking = initScrollTracking();
			}
		</script>
	</body>
</html>

---
import { GITHUB_URL, SITE_TITLE } from '../consts';

const today = new Date();
---

<footer class="mt-auto border-t border-border/80 py-8">
	<div class="mx-auto flex w-full max-w-screen-xl flex-col gap-5 px-6 sm:px-8">
		<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
			<div>
				<p class="m-0 text-sm font-medium text-foreground">{SITE_TITLE}</p>
				<p class="m-0 mt-1 text-sm text-muted-foreground">
					Infra stuff, written down.
				</p>
			</div>

			<a
				href={GITHUB_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 self-start rounded-full border border-border/70 bg-card px-4 py-2 text-sm font-medium text-foreground no-underline transition-all hover:-translate-y-0.5"
			>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16">
					<path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path>
				</svg>
				<span>github.com/pelindung-bumi</span>
			</a>
		</div>

		<div class="flex flex-col gap-2 border-t border-border/70 pt-4 text-sm text-muted-foreground sm:flex-row sm:items-center sm:justify-between">
			<p class="m-0">&copy; {today.getFullYear()} Pelindung Bumi.</p>
			<p class="m-0">We run into problems, figure them out, and write them down.</p>
		</div>
	</div>
</footer>
